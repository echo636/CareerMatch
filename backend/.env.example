FLASK_APP=run.py
FLASK_DEBUG=1
PORT=5000
FRONTEND_ORIGIN=http://localhost:3000
LLM_PROVIDER=qwen
EMBEDDING_PROVIDER=qwen
QDRANT_URL=http://localhost:6333
POSTGRES_DSN=postgresql://careermatch:careermatch@localhost:5432/careermatch
OBJECT_STORAGE_BUCKET=careermatch-resumes
OBJECT_STORAGE_ROOT=uploads
JOB_DATA_PATH=data/sample_jobs.json
JOB_DATA_LIMIT=
APP_STATE_DB_PATH=data/app_state.sqlite3
APP_LOG_DIR=logs
APP_LOG_LEVEL=INFO
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TIMEOUT_SEC=120
DASHSCOPE_LLM_RETRY_COUNT=2
DASHSCOPE_LLM_RETRY_BACKOFF_SEC=2.0
QWEN_LLM_MODEL=qwen-plus-latest
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024
